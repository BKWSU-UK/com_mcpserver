<?xml version="1.0" encoding="utf-8"?>
<extension type="component" version="5.0" method="upgrade">
    <name>com_mcpserver</name>
    <author>AI Assistant</author>
    <creationDate>2025-08-13</creationDate>
    <version>0.4.0</version>
    <license>GPL-2.0-or-later</license>
    <description>MCP Server component (JSON-RPC over HTTP and WebSocket) for Joomla</description>
    <namespace path="src">Joomla\Component\Mcpserver</namespace>
    <extension>
        <component>Joomla\Component\Mcpserver\Administrator\Extension\McpserverComponent</component>
        <providers>
            <provider path="services/provider.php"/>
        </providers>
    </extension>
    <site>
        <namespace path="src">Joomla\Component\Mcpserver\Site</namespace>
        <files folder="site">
            <filename>mcpserver.php</filename>
            <filename>router.php</filename>
            <folder>src</folder>
            <folder>services</folder>
        </files>
    </site>

    <scriptfile>script.php</scriptfile>

    <administration>
        <namespace path="src">Joomla\Component\Mcpserver</namespace>
        <menu>MCP Server</menu>
        <submenu>
            <menu link="option=com_mcpserver">Options</menu>
        </submenu>
        <languages folder="admin/language">
            <language tag="en-GB">en-GB/en-GB.com_mcpserver.ini</language>
            <language tag="en-GB">en-GB/en-GB.com_mcpserver.sys.ini</language>
        </languages>
        <files folder="admin">
            <filename>mcpserver.php</filename>
            <filename>config.xml</filename>
            <filename>access.xml</filename>
            <folder>src</folder>
            <folder>tmpl</folder>
            <folder>services</folder>
            <folder>vendor</folder>
        </files>
    </administration>

    <config>
        <fields name="params">
            <fieldset name="basic" label="COM_MCPSERVER_CONFIG_FIELDSET_BASIC">
                <field name="base_url" type="url" label="COM_MCPSERVER_CONFIG_BASE_URL" description="COM_MCPSERVER_CONFIG_BASE_URL_DESC" />
                <field name="api_token" type="textarea" label="COM_MCPSERVER_CONFIG_API_TOKEN" description="COM_MCPSERVER_CONFIG_API_TOKEN_DESC" filter="raw" rows="3" cols="80" />
                <field name="default_language" type="text" label="COM_MCPSERVER_CONFIG_DEFAULT_LANGUAGE" description="COM_MCPSERVER_CONFIG_DEFAULT_LANGUAGE_DESC" default="*" />
                <field name="cache_ttl" type="integer" label="COM_MCPSERVER_CONFIG_CACHE_TTL" description="COM_MCPSERVER_CONFIG_CACHE_TTL_DESC" default="60" />
                <field name="ws_host" type="text" label="COM_MCPSERVER_CONFIG_WS_HOST" description="COM_MCPSERVER_CONFIG_WS_HOST_DESC" default="0.0.0.0" />
                <field name="ws_port" type="integer" label="COM_MCPSERVER_CONFIG_WS_PORT" description="COM_MCPSERVER_CONFIG_WS_PORT_DESC" default="9077" />
            </fieldset>
            <fieldset name="security" label="COM_MCPSERVER_CONFIG_FIELDSET_SECURITY">
                <field name="require_auth" type="radio" label="COM_MCPSERVER_CONFIG_REQUIRE_AUTH" description="COM_MCPSERVER_CONFIG_REQUIRE_AUTH_DESC" default="1" class="btn-group">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field name="mcp_bearer_token" type="password" label="COM_MCPSERVER_CONFIG_MCP_BEARER_TOKEN_LABEL" description="COM_MCPSERVER_CONFIG_MCP_BEARER_TOKEN_DESC" filter="raw" />
                <field name="ip_allow_list" type="textarea" label="COM_MCPSERVER_CONFIG_IP_ALLOW_LIST" description="COM_MCPSERVER_CONFIG_IP_ALLOW_LIST_DESC" rows="3" />
                <field name="allowed_origins" type="textarea" label="COM_MCPSERVER_CONFIG_ALLOWED_ORIGINS" description="COM_MCPSERVER_CONFIG_ALLOWED_ORIGINS_DESC" rows="3" />
                <field name="trusted_proxies" type="textarea" label="COM_MCPSERVER_CONFIG_TRUSTED_PROXIES" description="COM_MCPSERVER_CONFIG_TRUSTED_PROXIES_DESC" rows="2" />
                <field name="rate_limit_requests" type="integer" label="COM_MCPSERVER_CONFIG_RATE_LIMIT_REQUESTS" default="60" description="COM_MCPSERVER_CONFIG_RATE_LIMIT_REQUESTS_DESC" />
                <field name="rate_limit_window" type="integer" label="COM_MCPSERVER_CONFIG_RATE_LIMIT_WINDOW" default="60" description="COM_MCPSERVER_CONFIG_RATE_LIMIT_WINDOW_DESC" />
            </fieldset>
        </fields>
    </config>
</extension>
